# GastroFlow SaaS Production Environment Configuration

# Server Settings
PORT=5000
NODE_ENV=production
# REQUIRED in production. Boot fails fast if missing or left as an insecure default.
# Generate a strong value, e.g.:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# PayHere Payment Gateway Credentials (Sri Lanka)
# The webhook signature check and checkout both resolve to this merchant secret.
# PAYHERE_MERCHANT_SECRET is the canonical name; PAYHERE_SECRET is accepted as an alias.
PAYHERE_MERCHANT_ID=1220000
PAYHERE_MERCHANT_SECRET=CHANGE_ME_PAYHERE_MERCHANT_SECRET
PAYHERE_NOTIFY_URL=https://api.yourdomain.com/api/payments/payhere/webhook
PAYHERE_SANDBOX=true

# Stripe Payment Gateway Credentials (International)
STRIPE_PUBLISHABLE_KEY=pk_test_51Px...
STRIPE_SECRET_KEY=sk_test_51Px...

# SMS & WhatsApp Gateway Credentials (Twilio / Dialog SMS)
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Database Configuration (Defaults to SQLite; set DATABASE_URL for PostgreSQL/AlloyDB)
# DATABASE_URL=postgres://user:password@localhost:5432/gastroflow_db
