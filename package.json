{
  "name": "restaurant-pos",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 3000 --host",
    "server": "node server.js",
    "start": "concurrently \"npm run server\" \"npm run dev\"",
    "start:all": "npx concurrently -k -n \"BACKEND,POS,FOOD,DRIVER\" -c \"cyan,blue,green,magenta\" \"npm run server\" \"npm run dev\" \"npm run customer:dev\" \"npm run driver:dev\"",
    "customer:dev": "vite apps/customer-web --port 3001 --host",
    "customer:build": "vite build apps/customer-web",
    "driver:dev": "vite apps/driver-web --port 3002 --host",
    "driver:build": "vite build apps/driver-web",
    "build": "vite build",
    "build:all": "vite build && vite build apps/customer-web --outDir apps/customer-web/dist && vite build apps/driver-web --outDir apps/driver-web/dist",
    "postinstall": "vite build && vite build apps/customer-web --outDir apps/customer-web/dist && vite build apps/driver-web --outDir apps/driver-web/dist",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "express-rate-limit": "^8.6.0",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.3",
    "leaflet": "^1.9.4",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.24.0",
    "sqlite3": "^5.1.7",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "supertest": "^7.2.2",
    "typescript": "^7.0.2",
    "vite": "^5.3.1",
    "vitest": "^1.6.1"
  }
}
